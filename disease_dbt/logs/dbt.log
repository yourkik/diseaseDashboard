),
deduped AS (
    SELECT
        *,
        ROW_NUMBER() OVER(PARTITION BY std_year, gender, disease_name ORDER BY loaded_at DESC, raw_id DESC) as rn
    FROM parsed_json
)

SELECT
    std_year,
    gender,
    disease_name,
    result_val
FROM deduped
WHERE rn = 1
  );
