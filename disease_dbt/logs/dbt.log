    FROM raw_extracted
    WHERE (item->>'icdNm')::text IN ('수두', '백일해', '유행성이하선염')
),
deduped AS (
    SELECT
        *,
        ROW_NUMBER() OVER(PARTITION BY std_year, age_range, disease_name ORDER BY loaded_at DESC, raw_id DESC) as rn
    FROM parsed_json
)

SELECT
    std_year,
    age_range,
    disease_name,
    result_val
FROM deduped
WHERE rn = 1
  );
