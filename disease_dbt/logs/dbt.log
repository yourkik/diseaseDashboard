    (item->>'year')::text AS std_year,
    (item->>'ageRange')::text AS age_range,
    (item->>'icdNm')::text AS disease_name,
    NULLIF(REPLACE((item->>'resultVal')::text, ',', ''), '')::integer AS result_val
FROM raw_extracted
WHERE (item->>'icdNm')::text IN ('수두', '백일해', '유행성이하선염')
  );
