# ==============================================================================
# 감염병 대시보드 프로젝트 (Disease Dashboard) Git Ignore 설정
# ==============================================================================

# 1. 공통 환경 변수 및 인증 정보 (절대 업로드하지 마세요)
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key

# 2. 파이썬 (Backend / EDA)
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
env/
.venv/
myenv/
backend/venv/
backend/env/
backend/myenv/

# Test & Debug Scripts
backend/debug_*.py
backend/test_*.py
backend/poll_*.py
backend/find_*.py
backend/fetch_*.py

# Cache Files
backend/app/services/kdca_cache.json

# 3. 노드 & 넥스트JS (Frontend)
# ------------------------------------------------------------------------------
node_modules/
frontend/node_modules/
.npm/
dist/
build/
.next/
out/
next-env.d.ts
*.tsbuildinfo

# 4. 데이터베이스 및 수집 데이터 (EDA)
# ------------------------------------------------------------------------------
*.sqlite3
db.sqlite3
backend/eda/data/
backend/eda/*.csv
backend/eda/*.png
backend/eda/test_out.xml
*.csv
*.zip
*.xlsx

# 5. OS 및 에디터 설정
# ------------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
mylogs/
mylogs.zip
Summary/

# 6. 문서 파일 무시
# 7. 임시 테스트 및 디버그 파일 무시
# ------------------------------------------------------------------------------
test_*.py
debug_*.py
scratch_*.py
test.py
client_source.txt
# Summary/ (GitHub 업로드를 위해 주석 처리)
de_venv/
Summary/

# 8. dbt (Data Build Tool)
# ------------------------------------------------------------------------------
disease_dbt/target/
disease_dbt/dbt_packages/
